generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
  SUPERADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ResourceType {
  PDF
  PPTX
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String?
  image         String?
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  level         Int       @default(1)
  xp            Int       @default(0)
  streakDays    Int       @default(0)
  lastActiveAt  DateTime?

  quizAttempts      QuizAttempt[]
  flashcardProgress FlashcardProgress[]
  topicProgress     TopicProgress[]
  badges            UserBadge[]
  interviewSessions InterviewSession[]
  accounts          Account[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Topic {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  icon        String
  color       String
  parentId    String?
  parent      Topic?        @relation("TopicChildren", fields: [parentId], references: [id])
  children    Topic[]       @relation("TopicChildren")
  order       Int           @default(0)
  status      ContentStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  flashcards          Flashcard[]
  quizzes             Quiz[]
  resources           Resource[]
  topicProgress       TopicProgress[]
  interviewCategories InterviewCategory[]

  @@index([slug])
  @@index([status])
}

model Flashcard {
  id         String        @id @default(cuid())
  topicId    String
  topic      Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  question   String
  answer     String
  hint       String?
  difficulty Difficulty    @default(MEDIUM)
  order      Int           @default(0)
  status     ContentStatus @default(PUBLISHED)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  progress   FlashcardProgress[]

  @@index([topicId])
}

model FlashcardProgress {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcardId    String
  flashcard      Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  known          Boolean   @default(false)
  reviewCount    Int       @default(0)
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, flashcardId])
  @@index([userId])
}

model Quiz {
  id           String        @id @default(cuid())
  topicId      String
  topic        Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  timeLimit    Int?
  passingScore Int           @default(70)
  status       ContentStatus @default(PUBLISHED)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  questions    QuizQuestion[]
  attempts     QuizAttempt[]

  @@index([topicId])
}

model QuizQuestion {
  id           String     @id @default(cuid())
  quizId       String
  quiz         Quiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question     String
  options      Json
  correctIndex Int
  explanation  String?
  difficulty   Difficulty @default(MEDIUM)
  order        Int        @default(0)

  answers      QuizAnswer[]

  @@index([quizId])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score       Int
  totalTime   Int
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  answers     QuizAnswer[]

  @@index([userId])
  @@index([quizId])
  @@index([userId, quizId])
}

model QuizAnswer {
  id            String       @id @default(cuid())
  attemptId     String
  attempt       QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId    String
  question      QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedIndex Int
  isCorrect     Boolean
  timeTaken     Int?

  @@index([attemptId])
}

model TopicProgress {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId         String
  topic           Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  masteryScore    Int      @default(0)
  flashcardsKnown Int      @default(0)
  flashcardsTotal Int      @default(0)
  quizzesTaken    Int      @default(0)
  avgQuizScore    Float    @default(0)
  timeSpent       Int      @default(0)
  lastAccessedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, topicId])
  @@index([userId])
}

model Resource {
  id            String        @id @default(cuid())
  topicId       String
  topic         Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  type          ResourceType
  fileName      String
  filePath      String
  fileSize      Int
  uploadedBy    String
  status        ContentStatus @default(PUBLISHED)
  downloadCount Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([topicId])
  @@index([type])
}

model InterviewCategory {
  id      String @id @default(cuid())
  name    String @unique
  slug    String @unique
  topicId String?
  topic   Topic? @relation(fields: [topicId], references: [id])

  sessions InterviewSession[]

  @@index([slug])
}

model InterviewSession {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId     String?
  category       InterviewCategory? @relation(fields: [categoryId], references: [id])
  jobDescription String             @db.Text
  detectedRole   String
  questions      Json
  createdAt      DateTime           @default(now())

  @@index([userId])
}

model Badge {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  criteria    Json

  users       UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([userId, action])
}
